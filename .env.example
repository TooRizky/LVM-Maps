# ============================================================
#  LVM-MAPS — Environment Variables
#  Salin file ini menjadi .env dan isi dengan nilai yang benar
# ============================================================

# ── Google Apps Script ──────────────────────────────────────
# URL dari deployment Google Apps Script Anda (Web App).
# Cara mendapatkan:
#   1. Buka Google Sheets → Extensions → Apps Script
#   2. Deploy → New Deployment → Web App
#   3. Execute as: Me | Who has access: Anyone
#   4. Copy URL yang dihasilkan
VITE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Supabase (untuk penyimpanan foto) ───────────────────────
# Project URL dari Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon Public Key atau Service Role Key dari Supabase Dashboard → Settings → API
# Gunakan anon key untuk keamanan lebih baik
VITE_SUPABASE_KEY=your_supabase_anon_or_service_role_key_here
